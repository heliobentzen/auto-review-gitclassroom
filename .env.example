# GitHub personal access token with repo and classroom scopes
GITHUB_TOKEN=your_github_token_here

# Optional: Ollama server URL for local AI-powered code reviews
OLLAMA_HOST=http://localhost:11434

# Optional: local model name previously pulled with `ollama pull`
OLLAMA_MODEL=qwen2.5-coder:7b

# Gemini API key (required when using provider=gemini)
GEMINI_API_KEY=

# Optional: Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Optional: base path when serving app behind reverse proxy (example: /auto-review)
APP_BASE_PATH=
